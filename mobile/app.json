{
  "expo": {
    "name": "Wingman",
    "slug": "wingman",
    "version": "0.1.0",
    "scheme": "wingman",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.wingman.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Wingman reads your most recent screenshot to instantly suggest replies."
      }
    },
    "android": {
      "package": "app.wingman.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Wingman reads your most recent screenshot to instantly suggest replies.",
          "savePhotosPermission": false,
          "isAccessMediaLocationEnabled": false,
          "preventAutomaticRemovalOfAccessMediaLocation": false,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Wingman needs photo access to read screenshots."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "48c58bd6-8026-416d-b830-aa37bfa4fe7f"
      }
    },
    "owner": "kevisatnorthumbria",
    "updates": {
      "url": "https://u.expo.dev/48c58bd6-8026-416d-b830-aa37bfa4fe7f",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "enabled": true
    }
  }
}
