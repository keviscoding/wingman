# Don't bloat the image — keep build context small + skip dev junk
.venv/
__pycache__/
*.pyc
*.pyo
.git/
.DS_Store
.cursor/
.expo/

# Local data — must NOT leak into the container, the volume mount
# provides this at runtime.
data/

# Mobile sources don't belong in the server image
mobile/
WINGMAN UI/
mockups/

# Training corpus ships in the image so #fullcorpus mode works.
# The precomputed Master Playbook is always used; the full corpus
# (121 txt files, ~2.5MB) is injected on-demand via #fullcorpus.
# .full_corpus.json cache is excluded (rebuilt at runtime).
training/.full_corpus.json

# Notebooks + dev scripts
*.ipynb
.ipynb_checkpoints/
build/
dist/
*.egg-info/

# Logs
*.log
/tmp/

# Editor
.idea/
.vscode/
