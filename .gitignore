# ── Python ──
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/

# ── OS / editor ──
.DS_Store
.idea/
.vscode/

# ── Secrets ──
.env
mobile/.env
*.pem
*.key
data/saas/.jwt_secret
# Firebase service account key (REAL secret — uploaded to EAS, never in git)
FIREBASE FILES/
*-firebase-adminsdk-*.json
# Note: mobile/google-services.json is NOT a secret. It's a config
# file pointing at the FCM project ID — it has to be in git so EAS
# Build can pick it up at build time.

# ── Local user data (provisioned via DO persistent disk in prod) ──
data/
chats/
case_studies/
examples_library/
training_dataset/
# training/ holds 100+ raw transcripts (private). DO NOT commit those.
# But the precomputed master playbook (.master_playbook.json) IS the
# whitelisted artifact the SaaS server needs to inject quality on Pro
# generations — keep it in git via the negation rule below.
training/*
!training/.master_playbook.json
presets.json
global_settings.json
wingman.log
*.log

# ── Tuning artifacts ──
# (master_playbook.json is whitelisted in the training/ block above —
#  it's the production artifact the SaaS server reads at boot.)
.examples_*.json
.summary_*.json

# ── Mobile (Expo / React Native) ──
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/.expo-shared/
mobile/ios/
mobile/android/
# Keep package-lock.json so EAS builds are reproducible.

# ── Misc ──
*.swp
*.swo
.cursor/

# ── Design source (not needed by the deploy / EAS) ──
WINGMAN UI/
wingman CHATS LOOK UPDATE/

# Local-only secret credential files - never commit
VERTEX AI JSON/
*.json.creds

# Google Cloud service account keys — NEVER commit these.
# Match every known auto-generated naming pattern so a stray download
# in the repo can't slip through. If you ever need a legitimate JSON
# file that matches one of these patterns, whitelist it with "!name".
*-service-account*.json
*-serviceaccount*.json
*-firebase-*.json
*-adminsdk-*.json
*iam.gserviceaccount.com*.json
nicheflix-*.json
wingman-*.json
muzo-*.json
google-services-*.json
gcp-*.json
vertex-*.json
# ALSO: if a raw .json file is sitting at the repo root it's almost
# always a mistake. Whitelist only the ones we explicitly need.
/*.json
